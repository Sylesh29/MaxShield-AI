# Copy this file to .env and fill in your keys before running.

# Required: Anthropic API key for Claude inference
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Required for W&B Weave tracing (recommended — it's the scoring criterion)
# Create a free account at https://wandb.ai/site
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=

# Optional: set to "disabled" to force-skip Weave even if WANDB_API_KEY is set
# WANDB_MODE=disabled

# Optional: model split for fast demos
# Fast assessment agents: Clinical Validator, Payer Compliance, Deep Audit
# CLAUDE_FAST_MODEL=claude-haiku-4-5
# Reasoning/final synthesis agent: Orchestrator Denial Predictor
# CLAUDE_REASONING_MODEL=claude-sonnet-4-6
# Backward-compatible fallback for the reasoning model
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: keep live demos from hanging on slow model calls
# The built-in critical NCCI demo uses a deterministic fast path by default.
# Set to 0 to force the full live-LLM path for every claim.
# MAXSHIELD_FAST_DEMO=1
# CLAUDE_TIMEOUT_SECONDS=90
# CLAUDE_MAX_RETRIES=1
# CLAUDE_MAX_TOKENS=4096
