# Copy this file to .env and fill in your keys before running.

# Required: Anthropic API key for Claude inference
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Required for W&B Weave tracing (recommended — it's the scoring criterion)
# Create a free account at https://wandb.ai/site
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=

# Optional: set to "disabled" to force-skip Weave even if WANDB_API_KEY is set
# WANDB_MODE=disabled

# Optional: override the default Claude model
# CLAUDE_MODEL=claude-sonnet-4-6
